---
import Django from "../assets/icons/Django.astro";
import Python from "../assets/icons/Python.astro";
import Wordpress from "../assets/icons/Wordpress.astro";
import Php from "../assets/icons/PHP.astro";
import Cafecito from "../assets/images/CafecitoParaOrar.png";
import Dashboard from "../assets/images/Dashboard.png";
import { PROJECTS } from "../data/portfolio";

// Mapea las claves de tag (definidas en portfolio.ts) a sus iconos y estilos.
const TAGS = {
  DJANGO: { name: "Django", class: "bg-white text-black", icon: Django },
  PYTHON: { name: "Python", class: "bg-white text-black", icon: Python },
  WORDPRESS: { name: "Wordpress", class: "bg-white text-black", icon: Wordpress },
  PHP: { name: "Php", class: "bg-white text-black", icon: Php },
} as const;

// Mapea las claves de imagen (en portfolio.ts) a los assets importados.
const IMAGES = {
  cafecito: Cafecito,
  dashboard: Dashboard,
} as const;
---

<div class="flex flex-col gap-8">
  {
    PROJECTS.map(({ image, title, description, link, github, tags }) => (
      <article
        class="group rounded-2xl border border-black/10 dark:border-white/10
        bg-black/[0.02] dark:bg-white/[0.03] p-5 md:p-6
        transition duration-300 hover:-translate-y-1
        hover:border-black/20 dark:hover:border-white/25
        hover:shadow-xl hover:shadow-black/5 dark:hover:shadow-black/40"
      >
        <h3 class="text-2xl font-semibold text-yellow-700 dark:text-yellow-200 mb-2">
          {title}
        </h3>
        <p class="text-base md:text-lg mb-4 text-pretty text-neutral-700 dark:text-gray-300">
          {description}
        </p>
        <ul class="flex gap-2 flex-row flex-wrap mb-4">
          {tags.map((tagKey) => {
            const tag = TAGS[tagKey as keyof typeof TAGS];
            const Icon = tag.icon;
            return (
              <li>
                <span
                  class={`flex items-center gap-x-2 rounded-full text-xs font-medium ${tag.class} py-1 px-2`}
                >
                  <Icon class="size-4" />
                  {tag.name}
                </span>
              </li>
            );
          })}
        </ul>
        <div class="overflow-hidden rounded-xl border border-black/10 dark:border-white/10">
          <img
            class="w-full transition duration-500 group-hover:scale-[1.03]"
            src={IMAGES[image as keyof typeof IMAGES].src}
            alt={`Imagen del proyecto ${title}`}
            loading="lazy"
          />
        </div>
        {(link !== "#" || github !== "#") && (
          <footer class="flex flex-wrap gap-3 mt-4">
            {link !== "#" && (
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-x-1.5 text-sm font-medium
                text-yellow-700 dark:text-yellow-200 hover:text-yellow-500 dark:hover:text-yellow-300 transition"
              >
                Ver proyecto →
              </a>
            )}
            {github !== "#" && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-x-1.5 text-sm font-medium
                text-neutral-600 dark:text-gray-400 hover:text-neutral-900 dark:hover:text-white transition"
              >
                Código →
              </a>
            )}
          </footer>
        )}
      </article>
    ))
  }
</div>
