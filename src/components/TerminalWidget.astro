---
import { PROFILE, SKILLS, EXPERIENCE, PROJECTS } from "../data/portfolio";

// Arte ASCII de bienvenida: un fantasma con teclado ("GhostyCode").
// Se guarda como string (String.raw) para no pelear con el escape de
// backslashes ni con la indentación del markup.
const GHOST_ART = String.raw`
                    :::
                ::::::::::::::
             -:::===:::::::::::::
            -::=+**++=-:::::-:::::
            -:=****++=::::::--:::--
           -:::=+++==:::::::-------
           -----::::---------------
      --------:::::::::::----:::---
    ---------=#***+==:-::::=+##*+--
      ---    +#=+%%%#=-:+**######:
             +=-:*@@*--:+%@@@%##%:
             +=--=@@*--::%@@@%##@=   ##
  ::         +#=:*@@%+::+@@@@#*#%= *%%#+
  --::::::::::++*@@@%%#%@@@@@*#%#+#***#*
  -----------:---#@@%%@@@@@@@**##%%#**+
-::::----------.-:*#%@@@@@@%#%#**###*+
-::::::::::--------:*@@@@@@%+%@%=+++*
      :===--:::=+*#%@@@@@@@@**@@+==*@#+
            *%%@@@@@@@@@@@@@%+*##*+#%@@#+:
           =%@@%@@@@@@@@%#%@@%####%%##*+
         =+##*+++#@@@@@@@%#%%@@%%#*#*
     ***+=*++++*+=*%%%#*#%%%##*+++++
          ++**+**++++++++++++++
`;
---

<!-- Burbuja flotante para abrir la terminal -->
<button
  id="term-bubble"
  type="button"
  aria-label="Abrir terminal interactiva"
  aria-expanded="false"
  aria-controls="term-panel"
  class="term-bubble fixed bottom-6 right-6 z-50 grid size-14 place-items-center rounded-full
  bg-neutral-900 text-white dark:bg-white dark:text-neutral-900
  shadow-lg shadow-black/30 ring-1 ring-black/10 dark:ring-white/20
  transition hover:scale-110 active:scale-95
  focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#7877c6]"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="size-6"
    ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
      d="M8 9l3 3l-3 3"></path><path d="M13 15l3 0"></path><path
      d="M3 4m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z"
    ></path></svg
  >
</button>

<!-- Panel de la terminal -->
<section
  id="term-panel"
  role="dialog"
  aria-label="Terminal interactiva de GhostyCode"
  aria-modal="false"
  class="hidden fixed z-50 flex-col overflow-hidden font-mono
  inset-0 rounded-none
  sm:inset-auto sm:bottom-6 sm:right-6 sm:w-full sm:max-w-md sm:h-[500px] sm:rounded-xl
  bg-white/95 dark:bg-[#0b0b13]/95 backdrop-blur-xl
  text-neutral-800 dark:text-gray-200
  border border-black/10 dark:border-white/10
  ring-1 ring-black/5 dark:ring-white/10
  shadow-2xl shadow-black/20 dark:shadow-black/60"
>
  <!-- Barra superior -->
  <header
    class="flex items-center justify-between gap-2 px-3 py-2.5 border-b
    border-black/10 dark:border-white/10 select-none
    bg-gradient-to-b from-black/[0.06] to-transparent dark:from-white/[0.08] dark:to-transparent"
  >
    <div class="flex items-center gap-2">
      <span class="flex gap-1.5" aria-hidden="true">
        <span class="size-3 rounded-full bg-red-400/90"></span>
        <span class="size-3 rounded-full bg-yellow-400/90"></span>
        <span class="size-3 rounded-full bg-green-400/90"></span>
      </span>
      <span class="text-xs text-neutral-500 dark:text-gray-400"
        >ghosty@portfolio: ~ (fish)</span
      >
    </div>
    <div class="flex items-center gap-1">
      <button
        id="term-min"
        type="button"
        aria-label="Minimizar terminal"
        title="Minimizar"
        class="grid size-7 place-items-center rounded transition
        hover:bg-black/10 dark:hover:bg-white/10
        focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#7877c6]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M5 12h14"></path></svg
        >
      </button>
      <button
        id="term-close"
        type="button"
        aria-label="Cerrar terminal"
        title="Cerrar"
        class="grid size-7 place-items-center rounded transition
        hover:bg-black/10 dark:hover:bg-white/10
        focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#7877c6]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M18 6l-12 12"></path><path d="M6 6l12 12"></path></svg
        >
      </button>
    </div>
  </header>

  <!-- Salida de la terminal -->
  <div
    id="term-output"
    aria-live="polite"
    aria-atomic="false"
    class="flex-1 overflow-y-auto px-3 py-2 text-sm leading-relaxed
    [scrollbar-width:thin]"
  >
  </div>

  <!-- Línea de entrada (técnica de input transparente con cursor propio) -->
  <div
    class="flex items-start gap-x-2 px-3 py-2 text-sm border-t
    border-black/10 dark:border-white/10"
  >
    <span class="shrink-0 select-none" aria-hidden="true">
      <span class="text-green-600 dark:text-green-400">ghosty</span
      ><span class="text-neutral-400 dark:text-gray-500">@</span
      ><span class="text-sky-600 dark:text-sky-400">portfolio</span>
      <span class="text-purple-600 dark:text-purple-400">~</span>
      <span class="text-green-600 dark:text-green-400">❯</span>
    </span>
    <div class="relative flex-1 min-w-0">
      <span id="term-typed" class="whitespace-pre-wrap break-all"></span
      ><span id="term-cursor" class="term-cursor">▋</span
      ><span
        id="term-ghost"
        class="text-neutral-400 dark:text-gray-600 whitespace-pre-wrap break-all"
      ></span>
      <input
        id="term-input"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="Entrada de comandos de la terminal"
        class="absolute inset-0 w-full bg-transparent text-transparent caret-transparent outline-none"
      />
    </div>
  </div>

  <!-- Plantilla de bienvenida (arte ASCII), clonada al iniciar y al hacer clear -->
  <template id="term-welcome">
    <div class="py-1">
      <pre
        aria-label="Logo de GhostyCode en arte ASCII"
        class="mx-auto w-fit text-purple-600 dark:text-purple-300 leading-[1.1] text-[11px] sm:text-[13px] overflow-x-auto">{GHOST_ART}</pre>
      <p class="mt-2 text-neutral-600 dark:text-gray-400">
        Terminal de <span
          class="text-yellow-600 dark:text-yellow-300 font-semibold">GhostyCode</span
        >.
      </p>
      <p class="text-neutral-600 dark:text-gray-400">
        Escribe <span class="text-yellow-600 dark:text-yellow-300 font-semibold"
          >help</span
        > y pulsa <span class="text-sky-600 dark:text-sky-400">Enter</span> para empezar.
        Usa <span class="text-sky-600 dark:text-sky-400">Tab</span> para autocompletar
        y <span class="text-sky-600 dark:text-sky-400">↑ ↓</span> para el historial.
      </p>
      <p class="mt-1 text-neutral-500 dark:text-gray-500 text-xs">
        Prueba <span class="text-yellow-600 dark:text-yellow-300">neofetch</span>,
        <span class="text-yellow-600 dark:text-yellow-300">ls</span> o
        <span class="text-yellow-600 dark:text-yellow-300">goto proyectos</span>.
      </p>
    </div>
  </template>
</section>

<script
  is:inline
  define:vars={{
    profile: PROFILE,
    skills: SKILLS,
    experience: EXPERIENCE,
    projects: PROJECTS,
  }}
>
  (function () {
    const panel = document.getElementById("term-panel");
    if (!panel || panel.dataset.ready === "true") return;
    panel.dataset.ready = "true";

    const bubble = document.getElementById("term-bubble");
    const output = document.getElementById("term-output");
    const input = document.getElementById("term-input");
    const typedEl = document.getElementById("term-typed");
    const ghostEl = document.getElementById("term-ghost");
    const welcomeTpl = document.getElementById("term-welcome");
    const minBtn = document.getElementById("term-min");
    const closeBtn = document.getElementById("term-close");

    const ACCENT = "text-yellow-600 dark:text-yellow-300 font-semibold";
    const LINK =
      "text-sky-600 dark:text-sky-400 underline underline-offset-2 hover:text-sky-500";
    const MUTED = "text-neutral-500 dark:text-gray-400";
    const CLEAR = {}; // centinela para el comando clear

    const PROMPT_HTML =
      '<span class="text-green-600 dark:text-green-400">ghosty</span>' +
      '<span class="text-neutral-400 dark:text-gray-500">@</span>' +
      '<span class="text-sky-600 dark:text-sky-400">portfolio</span> ' +
      '<span class="text-purple-600 dark:text-purple-400">~</span> ' +
      '<span class="text-green-600 dark:text-green-400">❯</span>';

    const esc = (s) =>
      String(s).replace(
        /[&<>"']/g,
        (c) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[c]
      );

    // Escapa y convierte **negrita** a <strong> (contenido propio y confiable).
    const fmtBold = (s) =>
      esc(s).replace(
        /\*\*(.+?)\*\*/g,
        '<strong class="text-neutral-900 dark:text-white font-semibold">$1</strong>'
      );

    // --- Historial y autocompletado ---
    const history = [];
    let historyIndex = 0;
    const START = Date.now();

    const JOKES = [
      "Hay 10 tipos de personas: las que entienden binario y las que no.",
      "Un programador va al gimnasio para mejorar su código… muscular.",
      "— ¿Por qué el dev quebró? — Porque se quedó sin caché.",
      "Iba a contar un chiste sobre UDP, pero quizá no lo recibas.",
      "99 bugs en el código, corriges uno… 127 bugs en el código.",
      "El SQL entró a un bar, se acercó a dos mesas y preguntó: ¿puedo hacer JOIN?",
    ];

    const COMMAND_LIST = [
      ["help", "Lista todos los comandos disponibles"],
      ["about", "Información breve sobre mí"],
      ["skills", "Tecnologías y herramientas que uso"],
      ["whoami", "Nombre, rol actual y especialidades"],
      ["neofetch", "Ficha de sistema estilo neofetch"],
      ["project", "Detalles de un proyecto: project <nombre>"],
      ["experience", "Resumen de mi experiencia laboral"],
      ["ai", "Cómo integro IA en mi flujo de desarrollo"],
      ["goto", "Navega a una sección: goto <about|exp|proyectos>"],
      ["ls", "Lista el contenido de este portafolio"],
      ["github", "Muestra y abre mi GitHub"],
      ["linkedin", "Muestra y abre mi LinkedIn"],
      ["contact", "Correo de contacto (copiable)"],
      ["mail", "Alias de contact"],
      ["coffee", "Recarga cafeína ☕"],
      ["joke", "Un chiste de programador"],
      ["echo", "Repite lo que escribas: echo <texto>"],
      ["history", "Muestra el historial de comandos"],
      ["date", "Fecha y hora actual"],
      ["theme", "Cambia el tema: theme [claro|oscuro]"],
      ["clear", "Limpia la pantalla y muestra el inicio"],
      ["exit", "Cierra la terminal"],
    ];
    const COMMAND_NAMES = COMMAND_LIST.map((c) => c[0]);

    function getSuggestion(value) {
      if (!value) return "";
      const lower = value.toLowerCase();
      // Completar el nombre de un proyecto tras "project "
      const m = value.match(/^project\s+(\S*)$/i);
      if (m) {
        const partial = m[1].toLowerCase();
        const proj = projects.find(
          (p) =>
            p.id.toLowerCase().startsWith(partial) ||
            p.title.toLowerCase().startsWith(partial)
        );
        if (proj) return "project " + proj.id;
        return "";
      }
      if (value.includes(" ")) return "";
      const match = COMMAND_NAMES.find(
        (c) => c.startsWith(lower) && c !== lower
      );
      return match || "";
    }

    function updateLine() {
      typedEl.textContent = input.value;
      const sug = getSuggestion(input.value);
      const lower = input.value.toLowerCase();
      ghostEl.textContent =
        sug && sug.toLowerCase().startsWith(lower) && sug.length > input.value.length
          ? sug.slice(input.value.length)
          : "";
    }

    // --- Salida ---
    function print(html) {
      const div = document.createElement("div");
      div.className = "mb-2";
      div.innerHTML = html;
      output.appendChild(div);
      output.scrollTop = output.scrollHeight;
    }

    function echo(value) {
      print(
        '<div class="flex gap-x-2"><span class="shrink-0 select-none">' +
          PROMPT_HTML +
          '</span><span class="break-all">' +
          esc(value) +
          "</span></div>"
      );
    }

    function renderWelcome() {
      output.appendChild(welcomeTpl.content.cloneNode(true));
      output.scrollTop = output.scrollHeight;
    }

    function clearScreen() {
      output.innerHTML = "";
      renderWelcome();
    }

    // --- Comandos ---
    const COMMANDS = {
      help() {
        const rows = COMMAND_LIST.map(
          ([name, desc]) =>
            '<div class="flex gap-x-3"><span class="' +
            ACCENT +
            ' w-24 shrink-0">' +
            name +
            '</span><span class="' +
            MUTED +
            '">' +
            desc +
            "</span></div>"
        ).join("");
        return "<div class=\"space-y-0.5\">" + rows + "</div>";
      },
      about() {
        return '<p class="text-pretty">' + esc(profile.about) + "</p>";
      },
      skills() {
        return skills
          .map(
            (g) =>
              '<div class="mb-1"><span class="' +
              ACCENT +
              '">' +
              esc(g.category) +
              ':</span> ' +
              g.items.map((i) => esc(i)).join(", ") +
              "</div>"
          )
          .join("");
      },
      whoami() {
        return (
          '<div><span class="' +
          ACCENT +
          '">' +
          esc(profile.name) +
          '</span> <span class="' +
          MUTED +
          '">(' +
          esc(profile.handle) +
          ")</span></div>" +
          "<div>" +
          esc(profile.role) +
          "</div>" +
          '<div class="' +
          MUTED +
          '">' +
          esc(profile.specialties.join(" · ")) +
          "</div>"
        );
      },
      experience() {
        return experience
          .map(
            (e) =>
              '<div class="mb-2">' +
              '<div class="text-sky-600 dark:text-sky-400 text-xs">' +
              esc(e.date) +
              "</div>" +
              '<div class="' +
              ACCENT +
              '">' +
              esc(e.title) +
              "</div>" +
              '<p class="' +
              MUTED +
              ' text-pretty whitespace-pre-line">' +
              fmtBold(e.description) +
              "</p></div>"
          )
          .join("");
      },
      project(args) {
        const list = projects
          .map((p) => '<span class="' + ACCENT + '">' + esc(p.id) + "</span>")
          .join(", ");
        const q = args.join(" ").toLowerCase().trim();
        if (!q) {
          return (
            "Uso: <span class=\"" +
            ACCENT +
            '">project &lt;nombre&gt;</span>.<br>Proyectos disponibles: ' +
            list
          );
        }
        const found = projects.find(
          (p) =>
            p.id.toLowerCase() === q ||
            p.id.toLowerCase().includes(q) ||
            p.title.toLowerCase().includes(q)
        );
        if (found) {
          return (
            '<div class="' +
            ACCENT +
            ' text-base">' +
            esc(found.title) +
            "</div>" +
            '<p class="' +
            MUTED +
            ' text-pretty mb-1">' +
            esc(found.description) +
            "</p>" +
            '<div class="text-xs ' +
            MUTED +
            ' mb-1">Stack: ' +
            found.tags.map((t) => esc(t)).join(", ") +
            "</div>" +
            (found.link && found.link !== "#"
              ? '<a class="' +
                LINK +
                '" href="' +
                esc(found.link) +
                '" target="_blank" rel="noopener noreferrer">' +
                esc(found.link) +
                "</a>"
              : "")
          );
        }
        return (
          'No encontré un proyecto que coincida con "<span class="text-red-500 dark:text-red-400">' +
          esc(q) +
          '</span>".<br>Prueba con: ' +
          list
        );
      },
      experiencia() {
        return COMMANDS.experience();
      },
      github() {
        window.open(profile.github, "_blank", "noopener");
        return (
          "Abriendo GitHub… " +
          '<a class="' +
          LINK +
          '" href="' +
          esc(profile.github) +
          '" target="_blank" rel="noopener noreferrer">' +
          esc(profile.github) +
          "</a>"
        );
      },
      linkedin() {
        window.open(profile.linkedin, "_blank", "noopener");
        return (
          "Abriendo LinkedIn… " +
          '<a class="' +
          LINK +
          '" href="' +
          esc(profile.linkedin) +
          '" target="_blank" rel="noopener noreferrer">' +
          esc(profile.linkedin) +
          "</a>"
        );
      },
      contact() {
        return (
          "Correo de contacto:<br>" +
          '<button type="button" data-copy="' +
          esc(profile.email) +
          '" class="' +
          ACCENT +
          ' cursor-pointer hover:underline" title="Clic para copiar">' +
          esc(profile.email) +
          "</button> " +
          '<span class="' +
          MUTED +
          ' text-xs">(clic para copiar)</span><br>' +
          '<a class="' +
          LINK +
          '" href="mailto:' +
          esc(profile.email) +
          '">Escribir un correo →</a>'
        );
      },
      mail() {
        return COMMANDS.contact();
      },
      date() {
        return new Date().toLocaleString("es-CO", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit",
        });
      },
      theme(args) {
        const a = (args[0] || "").toLowerCase();
        let target;
        if (["claro", "light", "dia", "día"].includes(a)) target = "light";
        else if (["oscuro", "dark", "noche"].includes(a)) target = "dark";
        else target = window.__getTheme() === "dark" ? "light" : "dark";
        window.__setTheme(target);
        return (
          "Tema cambiado a <span class=\"" +
          ACCENT +
          '">' +
          (target === "dark" ? "oscuro" : "claro") +
          "</span>."
        );
      },
      clear() {
        return CLEAR;
      },
      neofetch() {
        const up = Math.max(1, Math.round((Date.now() - START) / 1000));
        const theme = window.__getTheme() === "dark" ? "oscuro 🌙" : "claro ☀️";
        const art =
          '<pre class="text-purple-600/90 dark:text-purple-300/90 leading-tight shrink-0">' +
          "  .-~~-.\n" +
          " / o  o \\\n" +
          " |  __  |\n" +
          " \\      /\n" +
          "  '-..-'" +
          "</pre>";
        const row = (k, v) =>
          '<div><span class="' + ACCENT + '">' + k + "</span> " + v + "</div>";
        const info =
          '<div class="text-xs sm:text-sm">' +
          '<div><span class="text-green-600 dark:text-green-400">' +
          esc(profile.handle.toLowerCase()) +
          '</span><span class="' +
          MUTED +
          '">@</span><span class="text-sky-600 dark:text-sky-400">portfolio</span></div>' +
          '<div class="' +
          MUTED +
          '">──────────────</div>' +
          row("OS:", "GhostOS 4.0 (Astro)") +
          row("Shell:", "fish 🐟") +
          row("Rol:", "Analista de Sistemas") +
          row("Editor:", "VS Code + IA") +
          row("Lenguajes:", "Python · SQL · JS") +
          row("DB:", "SQL Server") +
          row("Tema:", theme) +
          row("Uptime:", up + "s") +
          "</div>";
        return (
          '<div class="flex gap-4 items-center">' + art + info + "</div>"
        );
      },
      ai() {
        return (
          '<p class="text-pretty">Integro <span class="' +
          ACCENT +
          '">inteligencia artificial</span> como una herramienta más de mi flujo: ' +
          "prototipado rápido, refactors, generación de queries y automatización de ETL. " +
          'La uso para ir más rápido, <span class="' +
          ACCENT +
          '">sin delegar el criterio</span>: entiendo y reviso todo lo que construyo. ' +
          "De hecho, esta terminal se armó así. 👻</p>"
        );
      },
      goto(args) {
        const map = {
          about: "sobre-mi",
          "sobre-mi": "sobre-mi",
          mi: "sobre-mi",
          exp: "experiencia",
          experiencia: "experiencia",
          experience: "experiencia",
          trabajo: "experiencia",
          proyectos: "proyectos",
          projects: "proyectos",
          proj: "proyectos",
        };
        const key = (args[0] || "").toLowerCase();
        const id = map[key];
        if (!id) {
          return (
            "goto: sección desconocida. Opciones: " +
            '<span class="' +
            ACCENT +
            '">about</span>, <span class="' +
            ACCENT +
            '">experiencia</span>, <span class="' +
            ACCENT +
            '">proyectos</span>.'
          );
        }
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        if (!window.matchMedia("(min-width: 640px)").matches) hidePanel();
        return "Navegando a <span class=\"" + ACCENT + '">#' + id + "</span> →";
      },
      cd(args) {
        return COMMANDS.goto(args);
      },
      pwd() {
        return '<span class="text-sky-600 dark:text-sky-400">~/portfolio/ghostycode</span>';
      },
      ls() {
        const dir = (n) =>
          '<span class="text-sky-600 dark:text-sky-400">' + n + "</span>";
        const file = (n) =>
          '<span class="' + MUTED + '">' + n + "</span>";
        return (
          '<div class="flex flex-wrap gap-x-4 gap-y-1">' +
          file("about.md") +
          file("skills.json") +
          file("whoami.sh") +
          dir("experiencia/") +
          dir("proyectos/") +
          file("contact.vcf") +
          file("ai.txt") +
          "</div>" +
          '<div class="' +
          MUTED +
          ' text-xs mt-1">Usa <span class="' +
          ACCENT +
          '">goto &lt;sección&gt;</span> para navegar.</div>'
        );
      },
      echo(args) {
        return args.length ? esc(args.join(" ")) : "";
      },
      history() {
        if (!history.length) return "Sin comandos en el historial todavía.";
        return history
          .map(
            (h, i) =>
              '<div><span class="' +
              MUTED +
              ' select-none mr-2">' +
              (i + 1) +
              "</span>" +
              esc(h) +
              "</div>"
          )
          .join("");
      },
      coffee() {
        const cup =
          '<pre class="text-yellow-700 dark:text-yellow-300/90 leading-tight">' +
          "    ( (\n" +
          "     ) )\n" +
          "  ........\n" +
          "  |      |]\n" +
          "  \\      /\n" +
          "   '----'" +
          "</pre>";
        return (
          '<div class="flex items-center gap-4">' +
          cup +
          "<div>Cafeína recargada. ☕<br><span class=\"" +
          MUTED +
          '">Pssst: mira el proyecto <span class="' +
          ACCENT +
          "\">cafecito</span>.</span></div></div>"
        );
      },
      joke() {
        return esc(JOKES[Math.floor(Math.random() * JOKES.length)]);
      },
      exit() {
        setTimeout(() => {
          closeReset();
          bubble.focus();
        }, 450);
        return "Cerrando terminal… 👋";
      },
      quit() {
        return COMMANDS.exit();
      },
      // --- Easter eggs (no listados en help) ---
      sudo() {
        return (
          '<span class="text-red-500 dark:text-red-400">🔒 Nice try.</span> ' +
          "Los fantasmas no necesitan root. Este incidente ha sido… ignorado. 👻"
        );
      },
      rm() {
        return "rm: no voy a borrar mi propio portafolio. 😅";
      },
      ghost() {
        return "👻  Boo! Soy <span class=\"" + ACCENT + '">GhostyCode</span>.';
      },
      matrix() {
        const chars = "01ﾊﾐﾋｰｳｼﾅﾓﾆｻﾜｵﾘﾎ";
        let rows = "";
        for (let r = 0; r < 5; r++) {
          let line = "";
          for (let c = 0; c < 30; c++) {
            line += chars[Math.floor(Math.random() * chars.length)];
          }
          rows += line + "\n";
        }
        return (
          '<pre class="text-green-500 dark:text-green-400 leading-tight">' +
          esc(rows) +
          "</pre>"
        );
      },
    };

    function runCommand(raw) {
      const value = raw.trim();
      echo(value);
      if (!value) return;
      const parts = value.split(/\s+/);
      const name = parts[0].toLowerCase();
      const args = parts.slice(1);
      const handler = COMMANDS[name];
      if (handler) {
        const res = handler(args);
        if (res === CLEAR) {
          clearScreen();
          return;
        }
        if (res) print(res);
      } else {
        print(
          '<span class="text-red-500 dark:text-red-400">bash: ' +
            esc(name) +
            ": comando no encontrado.</span> Escribe <span class=\"" +
            ACCENT +
            '">help</span> para ver los comandos disponibles.'
        );
      }
    }

    // --- Eventos de entrada ---
    input.addEventListener("input", updateLine);

    input.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        e.preventDefault();
        hidePanel();
        bubble.focus();
        return;
      }
      if (e.key === "Enter") {
        e.preventDefault();
        const value = input.value;
        if (value.trim()) {
          history.push(value.trim());
        }
        historyIndex = history.length;
        runCommand(value);
        input.value = "";
        updateLine();
      } else if (e.key === "Tab") {
        e.preventDefault();
        const sug = getSuggestion(input.value);
        if (sug) {
          input.value = sug;
          updateLine();
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (history.length && historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
          updateLine();
        }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        } else {
          historyIndex = history.length;
          input.value = "";
        }
        updateLine();
      } else if (e.key === "ArrowRight" || e.key === "End") {
        // Aceptar la sugerencia ghost si el cursor está al final
        if (input.selectionStart === input.value.length) {
          const sug = getSuggestion(input.value);
          if (sug && sug !== input.value) {
            e.preventDefault();
            input.value = sug;
            updateLine();
          }
        }
      }
    });

    // Copiar el correo desde el output
    output.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-copy]");
      if (!btn) return;
      const text = btn.getAttribute("data-copy");
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(() => {
          const prev = btn.textContent;
          btn.textContent = "¡copiado!";
          setTimeout(() => (btn.textContent = prev), 1200);
        });
      }
    });

    // Al hacer clic en el cuerpo del panel, enfocar el input (salvo en controles)
    panel.addEventListener("mousedown", (e) => {
      if (e.target.closest("a, button, [data-copy]")) return;
      // Evita robar la selección de texto del usuario
      if (window.getSelection && String(window.getSelection())) return;
      setTimeout(() => input.focus(), 0);
    });

    // --- Abrir / cerrar / minimizar ---
    function openPanel(focusInput = true) {
      panel.classList.remove("hidden");
      panel.classList.add("flex");
      bubble.classList.add("hidden");
      bubble.setAttribute("aria-expanded", "true");
      output.scrollTop = output.scrollHeight;
      if (focusInput) setTimeout(() => input.focus(), 0);
    }

    function hidePanel() {
      panel.classList.add("hidden");
      panel.classList.remove("flex");
      bubble.classList.remove("hidden");
      bubble.setAttribute("aria-expanded", "false");
    }

    function closeReset() {
      hidePanel();
      clearScreen();
      input.value = "";
      updateLine();
    }

    bubble.addEventListener("click", openPanel);
    minBtn.addEventListener("click", () => {
      hidePanel();
      bubble.focus();
    });
    closeBtn.addEventListener("click", () => {
      closeReset();
      bubble.focus();
    });

    // --- Inicio ---
    // La terminal arranca cerrada (como burbuja). Se abre al hacer clic.
    renderWelcome();
    updateLine();
  })();
</script>

<style>
  /* Anillo suave y pulsante en la burbuja para invitar a interactuar.
     Usa el púrpura del gradiente ambiental del sitio para dar cohesión. */
  .term-bubble::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    box-shadow: 0 0 0 0 rgba(120, 119, 198, 0.45);
    animation: term-pulse 2.6s ease-out infinite;
  }

  @keyframes term-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(120, 119, 198, 0.4);
    }
    70% {
      box-shadow: 0 0 0 12px rgba(120, 119, 198, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(120, 119, 198, 0);
    }
  }

  /* Scrollbar temático para el output */
  #term-output {
    scrollbar-width: thin;
    scrollbar-color: rgba(120, 119, 198, 0.5) transparent;
  }
  #term-output::-webkit-scrollbar {
    width: 8px;
  }
  #term-output::-webkit-scrollbar-thumb {
    background-color: rgba(120, 119, 198, 0.5);
    border-radius: 9999px;
  }

  .term-cursor {
    animation: term-blink 1.1s steps(1) infinite;
  }

  @keyframes term-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-cursor,
    .term-bubble::after {
      animation: none;
    }
  }
</style>
