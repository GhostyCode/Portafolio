<!-- SQL icon: cilindro de base de datos con texto -->
<svg role="img" aria-labelledby="sqlTitle" viewBox="0 0 256 256" width="256" height="256" xmlns="http://www.w3.org/2000/svg">
  <title id="sqlTitle">Icono SQL</title>
  <defs>
    <linearGradient id="gSQL" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0" stop-color="#4A90E2"/>
      <stop offset="1" stop-color="#2C6EB7"/>
    </linearGradient>
    <filter id="fShadow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="0" dy="6" stdDeviation="10" flood-color="#000" flood-opacity="0.18"/>
    </filter>
  </defs>

  <!-- sombra -->
  <ellipse cx="128" cy="200" rx="72" ry="12" fill="#000" fill-opacity="0.08"/>

  <!-- cilindro -->
  <g filter="url(#fShadow)">
    <!-- tapa superior (elipse) -->
    <ellipse cx="128" cy="70" rx="80" ry="26" fill="url(#gSQL)"/>
    <!-- cuerpo (rectángulo con bordes redondeados simulado con path) -->
    <path d="M48 70v72c0 14.33 35.82 26 80 26s80-11.67 80-26V70" fill="url(#gSQL)"/>
    <!-- borde inferior (elipse) -->
    <ellipse cx="128" cy="168" rx="80" ry="26" fill="#1C496F" opacity="0.18"/>
  </g>

  <!-- líneas horizontales internas para dar aspecto por niveles -->
  <g opacity="0.14" fill="#fff">
    <ellipse cx="128" cy="88" rx="64" ry="10"/>
    <ellipse cx="128" cy="108" rx="64" ry="10"/>
    <ellipse cx="128" cy="128" rx="64" ry="10"/>
    <ellipse cx="128" cy="148" rx="64" ry="10"/>
  </g>

  <!-- texto SQL -->
  <text x="128" y="208" font-family="Inter, Arial, Helvetica, sans-serif" font-size="36" font-weight="700" text-anchor="middle" fill="#0B2440">SQL</text>
</svg>
